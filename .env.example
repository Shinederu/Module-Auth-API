# --- APPLICATION AUTH ---
BASE_API=https://api.shinederu.ch/auth/
ALLOWED_MIME=image/png,image/jpeg,image/webp
SESSION_DURATION_HOURS=168

# --- DATABASE ---
DB_TYPE=mysql
DB_HOST=192.168.10.10
DB_PORT=3306
DB_NAME=ShinedeCore
DB_USER=authenticator
DB_PASS=change_me

# Auth does not publish Mercure events currently.

# --- MAIL ---
SMTP_HOST=mail.infomaniak.com
SMTP_AUTH=true
SMTP_USER=contact@example.com
SMTP_PASS=change_me
SMTP_PORT=587
SMTP_SECURE=starttls
SMTP_FROM=contact@example.com
SMTP_NAME="Shinederu Authentificator"
